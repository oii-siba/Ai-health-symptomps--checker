{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "logo.jpg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/styles\\.css",
      "dest": "/styles.css"
    },
    {
      "src": "/app\\.js",
      "dest": "/app.js"
    },
    {
      "src": "/logo\\.jpg",
      "dest": "/logo.jpg"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index\\.html",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
